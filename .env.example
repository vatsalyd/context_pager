# Context Pager Configuration
# Copy to .env and fill in values

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=pager
POSTGRES_USER=pager
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://pager:changeme@postgres:5432/pager

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Ollama (self-hosted, optional) ────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_ENABLED=false

# ── Auth & Security ──────────────────────────────────────────
SECRET_KEY=change-this-in-production
API_KEY_PREFIX=pgr_

# ── Embeddings ───────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ── Compression ──────────────────────────────────────────────
LLMLINGUA_MODEL=microsoft/llmlingua-2-xlm-roberta-large-meetingbank
DEFAULT_MAX_RETURN_TOKENS=2048

# ── Rate Limits (free tier) ─────────────────────────────────
RATE_LIMIT_TOOL_CALLS_PER_HOUR=100
RATE_LIMIT_TOKENS_PER_DAY=500000

# ── Observability ────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Deployment ───────────────────────────────────────────────
MCP_PORT=8000
DASHBOARD_PORT=8501
PUBLIC_URL=https://pager.duckdns.org
