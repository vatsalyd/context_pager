# Context Pager Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://pager:password@localhost:5432/pager
PG_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama (self-hosted only)
OLLAMA_URL=http://localhost:11434
OLLAMA_ENABLED=false

# Embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=12
EMBEDDING_MAX_LENGTH=8192

# Compression
LLMLINGUA_MODEL=microsoft/llmlingua-2-xlm-roberta-large-meetingbank
DEFAULT_MAX_RETURN_TOKENS=2048

# Auth
SECRET_KEY=dev-secret-change-in-production
API_KEY_PREFIX=pgr_

# Rate Limits (free tier)
RATE_LIMIT_TOOL_CALLS_PER_HOUR=100
RATE_LIMIT_TOKENS_PER_DAY=500000
RATE_LIMIT_MAX_DOCS=100
RATE_LIMIT_MAX_SESSIONS=2

# Observability
LOG_LEVEL=INFO

# Hosting
PUBLIC_URL=https://pager.duckdns.org