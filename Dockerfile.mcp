FROM python:3.12-slim

WORKDIR /app

# System deps for building native extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Set uv environment
ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PYTHON=python3.12

# Copy lockfile + project metadata
COPY pyproject.toml uv.lock README.md ./

# Pre-install CPU-only torch BEFORE uv sync (avoids CUDA pull-in)
RUN uv pip install --system --no-cache-dir \
    --index-url https://download.pytorch.org/whl/cpu \
    torch torchvision torchaudio

# Install remaining deps (will use already-installed torch)
RUN uv sync --frozen --no-dev --no-install-project

# Copy source code
COPY src ./src

# Install the project itself
RUN uv sync --frozen --no-dev

EXPOSE 8000
CMD ["uv", "run", "python", "-m", "context_pager.server"]